      "workingDirectory": ".",
      "launchBrowser": true,
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "applicationUrl": "https://localhost:51347;http://localhost:51348"
    }
  }
}