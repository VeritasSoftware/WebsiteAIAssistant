<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Helpers\PreTestAttributes.cs" />
    <Compile Remove="Helpers\xUnitAddons.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Data\SampleWebsite-AI-Model-CarCategory-MultipleFeatureColumns.zip" />
    <None Remove="SampleWebsite-AI-Model-CreateModel-List.zip" />
    <None Remove="SampleWebsite-AI-Model.zip" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Data\SampleWebsite-AI-Model-CarCategory-MultipleFeatureColumns.zip">
